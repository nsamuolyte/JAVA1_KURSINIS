<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="460" prefWidth="650" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.budgetboltfood.fxControllers.MainForm.OrderTab">

    <children>

        <!-- Kairė pusė – meniu / order list -->
        <AnchorPane layoutX="9.0" layoutY="14.0" prefHeight="440.0" prefWidth="413.0">
            <children>
                <ListView fx:id="menu" layoutY="83.0" prefHeight="357.0" prefWidth="200.0" />

                <ComboBox fx:id="orderDriver" prefWidth="150.0" promptText="DRIVER" />

                <ComboBox fx:id="status" layoutY="40.0" prefWidth="150.0" promptText="STATUS" />
            </children>
        </AnchorPane>

        <!-- Dešinė pusė – kliento order -->
        <AnchorPane fx:id="userOrder" layoutX="435.0" layoutY="4.0" prefHeight="461.0" prefWidth="223.0">
            <children>

                <Button fx:id="sendOrderBtn" layoutX="16.0" layoutY="119.0" onAction="#sendOrder" text="SEND ORDER" />

                <ComboBox fx:id="atsiemimoBudas" layoutX="15.0" layoutY="87.0" prefWidth="150.0" promptText="Pick-up method" />

                <Label fx:id="kainaLbl" layoutX="13.0" layoutY="189.0" text="Price:" />
                <Label fx:id="kiekisLbl" layoutX="13.0" layoutY="206.0" text="Quantity:" />

                <ListView fx:id="alergenai" layoutX="15.0" layoutY="226.0" prefHeight="200.0" prefWidth="170.0" />

                <ComboBox fx:id="restaurantPicker" layoutX="15.0" layoutY="55.0" prefHeight="26.0" prefWidth="170.0" promptText="RESTAURANT" />

            </children>
        </AnchorPane>

    </children>

</AnchorPane>
