<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="menuRoot" prefHeight="320.0" prefWidth="626.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.budgetboltfood.fxControllers.MainForm.MenuTab">

    <children>
        <ListView fx:id="cuisineView" layoutX="14.0" layoutY="10.0" prefHeight="300" prefWidth="402.0" />

        <VBox layoutX="431.0" layoutY="14.0" spacing="10">
            <ComboBox fx:id="selectRestaurant" prefWidth="139.0" promptText="Restaurant" />
            <ComboBox fx:id="cuisineTypeBox" prefWidth="139.0" promptText="Cuisine Type" />
            <ComboBox fx:id="ingredientsBox" prefWidth="139.0" promptText="Ingredients" />
            <ComboBox fx:id="alergensBox" prefWidth="139.0" promptText="Alergens" />
            <ComboBox fx:id="portionSizeBox" prefHeight="26.0" prefWidth="139.0" promptText="Portion Size" />
            <TextField fx:id="descriptionField" prefHeight="26.0" prefWidth="137.0" promptText="Dish name" />
            <Button onAction="#saveCuisine" prefWidth="139.0" text="SAVE" />
         <Button onAction="#deleteCuisine" prefWidth="139.0" text="DELETE" />
        </VBox>
    </children>
</AnchorPane>
