<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.budgetboltfood.fxControllers.MainForm.AdminTable">

    <TableView fx:id="adminTableView" layoutX="0" layoutY="0" prefHeight="400" prefWidth="600">
        <columns>
            <TableColumn fx:id="adminIdColumn" prefWidth="60" text="ID" />
            <TableColumn fx:id="adminNameColumn" prefWidth="155.0" text="NAME" />
            <TableColumn fx:id="adminEmailColumn" prefWidth="155.0" text="EMAIL" />
            <TableColumn fx:id="adminPasswordColumn" prefWidth="171.0" text="PASSWORD" />
            <TableColumn fx:id="adminDeleteColumn" prefWidth="58.0" text="DELETE" />
        </columns>
    </TableView>

</AnchorPane>
